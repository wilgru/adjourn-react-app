{
  "name": "adjourn-react-app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "dist-electron/main.js",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "trap 'cd ./pocketbase && docker compose down' EXIT; npm run start:pocketbase && npm run start:vite",
    "start:pocketbase": "cd ./pocketbase && docker compose down && docker compose up -d",
    "start:vite": "vite",
    "build": "tsc && vite build",
    "electron:dev": "ELECTRON=true VITE_ELECTRON=true vite",
    "electron:build": "ELECTRON=true VITE_ELECTRON=true tsc && ELECTRON=true VITE_ELECTRON=true vite build && electron-builder",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "lint:fix": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0 --fix",
    "prettier": "prettier . --check",
    "prettier:fix": "prettier . --check --write",
    "preview": "vite preview",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "@phosphor-icons/react": "^2.1.5",
    "@radix-ui/react-dialog": "^1.1.1",
    "@radix-ui/react-dropdown-menu": "^2.1.1",
    "@radix-ui/react-toggle-group": "^1.1.0",
    "@radix-ui/react-tooltip": "^1.2.7",
    "@tanstack/react-devtools": "^0.10.0",
    "@tanstack/react-query": "^5.28.14",
    "@tanstack/react-query-devtools": "^5.28.14",
    "@tanstack/react-router": "^1.167.0",
    "@tanstack/react-start": "^1.166.16",
    "@types/quill": "^2.0.14",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dayjs": "^1.11.10",
    "debounce": "^1.2.1",
    "jotai": "^2.12.5",
    "localforage": "^1.10.0",
    "match-sorter": "^6.3.1",
    "pocketbase": "^0.25.0",
    "quill": "^1.3.7",
    "quill-delta": "^5.1.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "sort-by": "^1.2.0",
    "tailwind-merge": "^2.5.5",
    "vite-plugin-svgr": "^4.2.0"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^3.2.6",
    "@flydotio/dockerfile": "^0.5.7",
    "@storybook/react": "^8.6.12",
    "storybook": "^8.6.12",
    "@tanstack/router-devtools": "^1.166.9",
    "@types/debounce": "^1.2.4",
    "@types/node": "^20.19.0",
    "@types/react": "^18.2.15",
    "@types/react-dom": "^18.2.7",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "@vitejs/plugin-react": "^5.0.0",
    "@vitest/browser": "^4.1.0",
    "@vitest/coverage-v8": "^4.1.0",
    "autoprefixer": "^10.4.16",
    "electron": "^41.0.2",
    "electron-builder": "^26.8.1",
    "eslint": "^8.45.0",
    "eslint-plugin-import": "^2.29.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.3",
    "eslint-plugin-storybook": "^0.12.0",
    "playwright": "^1.52.0",
    "postcss": "^8.4.31",
    "tailwindcss": "^3.3.5",
    "typescript": "^5.0.2",
    "vite": "^7.0.0",
    "vite-plugin-electron": "^0.29.1",
    "vitest": "^4.1.0"
  },
  "build": {
    "appId": "com.adjourn.app",
    "productName": "Adjourn",
    "executableName": "Adjourn",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**",
      "dist-electron/**"
    ],
    "extraResources": [
      {
        "from": "pocketbase/",
        "to": ".",
        "filter": [
          "pocketbase",
          "pocketbase.exe"
        ]
      }
    ],
    "mac": {
      "category": "public.app-category.productivity"
    }
  }
}
